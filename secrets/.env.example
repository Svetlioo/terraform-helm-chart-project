# =============================================================================
# SECRETS CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp secrets/.env.example secrets/.env
#
# This .env file is used by:
#   - Docker Compose (for local non-K8s development)
#   - Terraform (reads these to create K8s secrets)
#   - Setup script (sources this for consistency)
#
# NEVER commit the .env file. Only .env.example is committed.
# =============================================================================

# --- Database passwords (one per environment) ---
DB_PASSWORD_DEV=change-me-dev
DB_PASSWORD_TEST=change-me-test
DB_PASSWORD_PROD=change-me-prod

# --- GitHub ---
GITHUB_USERNAME=YOUR_USERNAME
GITHUB_REPO=terraform-helm-chart-project
# Personal Access Token — needs two scopes:
#   read:packages  (k3d can pull images from ghcr.io)
#   repo           (ArgoCD can pull from a private IaC repo)
# Generate at: https://github.com/settings/tokens -> Fine-grained tokens
GITHUB_TOKEN=ghp_your_token_here

# --- ArgoCD ---
# Leave empty to use auto-generated password (recommended)
ARGOCD_ADMIN_PASSWORD=
